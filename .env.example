# LLM backend: local | claude_code
LLM_BACKEND=local

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Claude Code CLI backend example:
# LLM_BACKEND=claude_code
# GRAPH_EXTRACTION_BACKEND=claude_code
# GRAPH_BUILD_MODE=claude_task
# CLAUDE_CODE_MODEL=claude-haiku-4-5
# CLAUDE_TASKS_DIR=/tmp/projectos-claude-tasks
# CLAUDE_TASK_BARE=false
# CLAUDE_TASK_TIMEOUT=600
# CLAUDE_GRAPH_DISABLE_PLUGINS=true

# Local OpenAI-compatible example:
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1

# Graph processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Claude Code can handle larger chunks for E2E quality tests, e.g.
# CHUNK_SIZE=1800
# CHUNK_OVERLAP=150
FUZZY_MATCH_THRESHOLD=0.85
MAX_ONTOLOGY_SAMPLE_CHARS=50000

# Storage paths
VAULT_DIR=./vault
PROJECTS_DIR=./projects

# Embedding model (optional — semantic deduplication is skipped if unset)
EMBEDDING_BASE_URL=http://localhost:14004/v1
EMBEDDING_MODEL=BAAI/bge-m3
SEMANTIC_DEDUP_THRESHOLD=0.88
